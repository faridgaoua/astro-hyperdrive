---
import { Image } from "astro:assets";
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Button from "~/components/Button.astro";
import Hero from "~/components/Hero.astro";
import Faq from "~/components/Faq.astro";
import Heading from "~/components/Heading.astro";
import WidgetSearch from "~/components/WidgetSearch.astro";
import Grid from "~/components/Grid.astro";
import GridItem from "~/components/GridItem.astro";
import ShowPosts from "~/components/ShowPosts.astro";
import Team from "~/components/Team.astro";
import Stats from "~/components/Stats.astro";
import ShowCars from "~/components/ShowCars.astro";

// Images
import ImageCarDealer from "~/assets/images/pexels-shkrabaanthony-7144179.jpg";
import ImageHeadingBackground from "~/assets/images/pexels-jeshoots-com-147458-451590.jpg";
import ImageOne from "~/assets/images/pexels-leif-bergerson-99376750-9764731.webp";
import ImageTwo from "~/assets/images/pexels-zenzazione-2922140.webp";
---

<Layout pageTitle="Home">
	{/* Main Heading - Optimized for LCP */}
	<Section class:list={"relative"}>
		<Image
			src={ImageHeadingBackground}
			alt="Heading background"
			widths={[800, 1200, 1600, ImageHeadingBackground.width]}
			sizes="100vw"
			loading="eager"
			fetchpriority="high"
			class:list={"absolute inset-0 w-full h-full object-cover"}
		/>
		<div class="absolute inset-0 w-full h-full object-cover bg-gray-800/80"></div>
		<Container class:list={"relative z-10"}>
			<Heading class:list={"prose-invert max-w-4xl"}>
				<h1 slot="heading-title" class="mb-0 lg:text-7xl text-balance">
					Find your next car in our exclusive collection
				</h1>
				<p slot="heading-content">
					Search for your next car here. We have a wide range of cars for sale. Browse through our collection
					and find the perfect car that suits your needs and budget.
				</p>
			</Heading>
			<WidgetSearch />
		</Container>
	</Section>

	{/* Hero - Fixed Oversized Image (1279px served vs 462px displayed) */}
	<Section>
		<Container>
			<Hero>
				<div slot="hero-left" class="prose lg:max-w-2xl">
					<h2>Welcome to our car dealer!</h2>
					<p>
						Find your next car here. We have a wide range of cars for sale. Browse through our collection
						and find the perfect car that suits your needs and budget.
					</p>
					<Button href="/cars" class:list={"mt-4"}>View all cars</Button>
				</div>
				<div slot="hero-right">
					<Image 
						src={ImageCarDealer} 
						alt="Car dealer" 
						widths={[480, 800]} 
						sizes="(max-width: 1024px) 100vw, 480px"
					/>
				</div>
			</Hero>
		</Container>
	</Section>

	{/* Grid - Fixed Responsive Sizes */}
	<Section>
		<Container>
			<Grid>
				{/* ImageOne - Displayed at 1216x811 */}
				<GridItem 
					image={ImageOne} 
					imageAlt="Car dealer" 
					span={2} 
					link="/cars" 
					As="a" 
					xl
					widths={[800, 1250]}
					sizes="(max-width: 1024px) 100vw, 800px"
				>
					<h2>Featured cars</h2>
					<p>Discover the ultimate driving experience...</p>
					<Button As="button" type="button" color="white-outline" class:list={"mt-4 group-hover:bg-white/10"}>View all cars</Button>
				</GridItem>

				{/* ImageTwo - Displayed at 732x488 */}
				<GridItem 
					image={ImageTwo} 
					imageAlt="Car dealer" 
					link="/cars" 
					As="a"
					widths={[400, 750]}
					sizes="(max-width: 768px) 100vw, 400px"
				>
					<h3>Featured cars</h3>
					<p>Discover the ultimate driving experience...</p>
					<Button As="button" type="button" color="white-outline" class:list={"mt-4 group-hover:bg-white/10"}>View all cars</Button>
				</GridItem>

				<GridItem>
					<h3>Featured cars</h3>
					<p>Discover the ultimate driving experience...</p>
				</GridItem>
			</Grid>
		</Container>
	</Section>

	{/* ... rest of the sections remain the same ... */}
    {/* TIP: Reuse the same logic for the second Hero Image below if it's the same asset */}
    <Section class:list={"bg-gray-50"}>
		<Container>
			<Hero invert>
				<div slot="hero-left" class="prose lg:max-w-2xl">
					<h2>Welcome to our car dealer!</h2>
					<p>Find your next car here...</p>
				</div>
				<div slot="hero-right">
					<Image 
						src={ImageCarDealer} 
						alt="Car dealer" 
						widths={[480, 800]} 
						sizes="(max-width: 1024px) 100vw, 480px"
					/>
				</div>
			</Hero>
		</Container>
	</Section>
    
    {/* Remaining sections (ShowCars, Stats, FAQ, Team) follow... */}
</Layout>